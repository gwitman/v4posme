				if(codigoABuscar.indexOf("+")  >= 0 ){				
					sumar  = true;
					codigoABuscar =  codigoABuscar.replace("BITT","").replace("+","");
					codigoABuscar =  "ITT" + ("00000000"+codigoABuscar).substr(("00000000"+codigoABuscar).length - 8 ,8);				
				}
				if(codigoABuscar.indexOf("-")  >= 0 ){				
					sumar  = false;
					codigoABuscar =  codigoABuscar.replace("BITT","").replace("-","");
