				backgroundColor : "#4eacc8" },500);
				$("#body_tb_transaction_master_detail tr")[objind_].animate({ 
				backgroundColor : "" },500);
			}
			
		}
		//Agregar
		else{
			objTableDetail.fnAddData([
				objRow.checked,
				objRow.transactionMasterDetailID,
				objRow.itemID,
				objRow.codigo,
				objRow.description,
				objRow.um,
				objRow.quantity,
				objRow.price,
				objRow.total,
				objRow.iva,
				0,
				0
			]);
			
