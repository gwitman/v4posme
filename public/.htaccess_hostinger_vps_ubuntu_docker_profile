FROM php:8.1-apache

# 🔧 Instalar librerías del sistema
RUN apt-get update && apt-get install -y \
    libicu-dev \
    libmemcached-dev \
    zlib1g-dev \
    libzip-dev \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    libssh2-1-dev \
    curl \
    unzip \
    memcached \
    && rm -rf /var/lib/apt/lists/*

# 🔧 Configurar GD (imágenes)
RUN docker-php-ext-configure gd \
    --with-freetype \
    --with-jpeg

# 🔧 Instalar extensiones PHP nativas
RUN docker-php-ext-install \
    intl \
    mysqli \
    pdo \
    pdo_mysql \
    gd \
    zip \
    opcache

# 🔧 Instalar extensiones vía PECL
RUN pecl install memcached \
    && pecl install ssh2-1.3.1 \
    && docker-php-ext-enable memcached ssh2 opcache

# 🔥 Activar mod_rewrite
RUN a2enmod rewrite

# 🚀 AQUÍ VA TU CONFIGURACIÓN DE MEMORIA
RUN echo "memory_limit=1024M" > /usr/local/etc/php/conf.d/memory-limit.ini

# ⚡ Optimización OPCACHE
RUN echo "opcache.enable=1" > /usr/local/etc/php/conf.d/opcache.ini \
 && echo "opcache.memory_consumption=128" >> /usr/local/etc/php/conf.d/opcache.ini \
 && echo "opcache.interned_strings_buffer=8" >> /usr/local/etc/php/conf.d/opcache.ini \
 && echo "opcache.max_accelerated_files=10000" >> /usr/local/etc/php/conf.d/opcache.ini \
 && echo "opcache.revalidate_freq=2" >> /usr/local/etc/php/conf.d/opcache.ini \
 && echo "opcache.fast_shutdown=1" >> /usr/local/etc/php/conf.d/opcache.ini

# ⚡ Permitir .htaccess
RUN sed -i 's/AllowOverride None/AllowOverride All/g' /etc/apache2/apache2.conf

# ⚡ Permisos recomendados
RUN chown -R www-data:www-data /var/www/html
